# Experiment: Micro‑law search with GRA obnulënka

We generate synthetic data for an object under constant force (F=2, m=1) with noise, and let GRA frames compete to discover the law.

## 1. Imports and data generation

```python
import numpy as np
import matplotlib.pyplot as plt
import sys
sys.path.append('..')
from src.core import GRAFrame, GRAResetController, GRAAgent, chi2
from src.domains.micro_physics import ConstantAccelFrame, LinearDragFrame, NewtonFrame

# Generate data: t from 0 to 10, x = 0.5*(F/m)*t^2 + noise
np.random.seed(42)
t = np.linspace(0, 10, 20)
F_true, m_true = 2.0, 1.0
x_true = 0.5 * (F_true/m_true) * t**2
x_obs = x_true + np.random.normal(0, 0.5, size=t.shape)
data = (t, x_obs)

plt.plot(t, x_obs, 'o', label='data')
plt.plot(t, x_true, '-', label='true law')
plt.legend()
plt.show()
```

## 2. Define frames and initial population

We create a few instances of each frame type with random initial parameters.

```python
frames = []
for _ in range(5):
    frames.append(ConstantAccelFrame(f"const_accel_{_}", meta={'type':'const'}))
    frames.append(LinearDragFrame(f"linear_drag_{_}", meta={'type':'drag'}))
    frames.append(NewtonFrame(f"newton_{_}", meta={'type':'newton'}))

# Random initialisation
for f in frames:
    if isinstance(f, ConstantAccelFrame):
        f.instantiate(a=np.random.uniform(0, 5))
    elif isinstance(f, LinearDragFrame):
        f.instantiate(k=np.random.uniform(0, 2), v0=np.random.uniform(0, 5))
    elif isinstance(f, NewtonFrame):
        f.instantiate(F=np.random.uniform(0, 5), m=np.random.uniform(0.5, 2))
```

## 3. Reset policy and agent

We'll keep top 30% survivors, kill the rest, and generate children by slightly perturbing parameters of survivors.

```python
def top_k_policy(scores, frames, k=0.3):
    sorted_frames = sorted(frames, key=lambda f: scores[f.name])
    n_keep = int(len(frames) * k)
    survivors = sorted_frames[:n_keep]
    killed = sorted_frames[n_keep:]
    return survivors, killed

def mutate_param(frame):
    # Simple mutation: perturb parameters slightly
    if isinstance(frame, ConstantAccelFrame):
        new_a = frame.params['a'] * np.random.uniform(0.9, 1.1)
        new_frame = ConstantAccelFrame(frame.name+'_child', parent=frame)
        new_frame.instantiate(a=new_a)
    elif isinstance(frame, LinearDragFrame):
        new_k = frame.params['k'] * np.random.uniform(0.9, 1.1)
        new_v0 = frame.params['v0'] * np.random.uniform(0.9, 1.1)
        new_frame = LinearDragFrame(frame.name+'_child', parent=frame)
        new_frame.instantiate(k=new_k, v0=new_v0)
    elif isinstance(frame, NewtonFrame):
        new_F = frame.params['F'] * np.random.uniform(0.9, 1.1)
        new_m = frame.params['m'] * np.random.uniform(0.9, 1.1)
        new_frame = NewtonFrame(frame.name+'_child', parent=frame)
        new_frame.instantiate(F=new_F, m=new_m)
    else:
        new_frame = frame  # fallback
    return new_frame

agent = GRAAgent([mutate_param])
controller = GRAResetController(frames, lambda s,f: top_k_policy(s,f,k=0.3))
```

## 4. Run reset cycles

```python
n_epochs = 20
history = []

for epoch in range(n_epochs):
    scores, survivors, killed = controller.step(data)
    history.append({f.name: scores[f.name] for f in controller.frames})
    # generate children
    children = [agent.propose_child(np.random.choice(survivors)) for _ in killed]
    controller.frames = survivors + children

# After loop, check best frame
best_frame = min(controller.frames, key=lambda f: f.score(data))
print(f"Best frame: {best_frame.name}, params: {best_frame.params}")
```

## 5. Visualise evolution

```python
# Plot best score over time
best_scores = [min(h.values()) for h in history]
plt.plot(best_scores)
plt.xlabel('Epoch')
plt.ylabel('Best score (chi2)')
plt.yscale('log')
plt.show()
```

## 6. Compare best model with data

```python
best_frame.score(data)   # should be low
t_plot = np.linspace(0,10,100)
if isinstance(best_frame, NewtonFrame):
    F, m = best_frame.params['F'], best_frame.params['m']
    x_model = 0.5 * (F/m) * t_plot**2
    plt.plot(t_plot, x_model, label='best model')
    plt.plot(t, x_obs, 'o', label='data')
    plt.legend()
    plt.title(f"F={F:.2f}, m={m:.2f}")
    plt.show()
```

The best frame should be a NewtonFrame with parameters close to (2,1).
